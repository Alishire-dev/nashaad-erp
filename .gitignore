# --- Environment / secrets: NEVER commit real credentials ---
.env

# --- Composer dependencies: regenerated via `composer install`, not committed ---
/vendor/

# --- Runtime / writable data: sessions, cache, logs, uploads ---
/writable/cache/*
!/writable/cache/index.html
/writable/logs/*
!/writable/logs/index.html
/writable/session/*
!/writable/session/index.html
/writable/uploads/*
!/writable/uploads/index.html
/writable/debugbar/*
!/writable/debugbar/index.html

# --- Uploaded item images: real files stay out of git, folder structure stays ---
/public/uploads/items/*
!/public/uploads/items/index.html

.DS_Store
Thumbs.db
.vscode/
.idea/

# --- One-time seed scripts with real creds if ever added ad hoc ---
seed_admin.php
